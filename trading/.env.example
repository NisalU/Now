# AI Crypto Trading System — Environment Variables
# Copy to .env and fill in your actual values

# ── Binance API (required) ────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Groq AI (required for AI signals) ────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Markets ───────────────────────────────────────────────────────────────────
DEFAULT_SYMBOL=BTCUSDT
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
KLINE_LIMIT=300

# ── AI Triggers ───────────────────────────────────────────────────────────────
AI_MIN_INTERVAL_SECONDS=60
AI_TRIGGER_15M_CLOSE=true
AI_TRIGGER_STRUCTURE_CHANGE=true
AI_TRIGGER_LIQUIDITY_SWEEP=true
AI_TRIGGER_HIGH_VOLATILITY=true

# ── Risk ──────────────────────────────────────────────────────────────────────
MIN_RISK_REWARD=2.0
MAX_ENTRY_ATR_DISTANCE=3.0

# ── Trade Manager ─────────────────────────────────────────────────────────────
BREAK_EVEN_TRIGGER_RR=1.0
TRAILING_STOP_ATR_MULT=1.5
PARTIAL_TP_PERCENT=0.5
